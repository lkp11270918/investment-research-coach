{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "compliance_gate_output.schema.json",
  "title": "ComplianceGateOutput",
  "type": "object",
  "required": [
    "gate_name",
    "status",
    "unsupported_claims",
    "evidence_issues",
    "downgraded_claims",
    "compliance_warnings",
    "rewrite_suggestions"
  ],
  "additionalProperties": false,
  "properties": {
    "gate_name": {
      "type": "string",
      "enum": ["pre_memo_gate", "post_memo_gate"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "downgraded_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["original_claim", "downgraded_expression"],
        "additionalProperties": false,
        "properties": {
          "original_claim": {
            "type": "string"
          },
          "downgraded_expression": {
            "type": "string"
          },
          "reason": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "compliance_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rewrite_suggestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
