{
  "workflow_name": "value_investing_research_workflow",
  "version": "0.1.0",
  "description": "Material-package-driven buy-side value investing research training workflow.",
  "nodes": [
    {
      "id": "firm_doctrine_case_retrieval",
      "agent": "Firm Doctrine & Case Retrieval Agent",
      "required_modes": ["to_b"],
      "optional_modes": ["to_c"],
      "depends_on": [],
      "outputs": ["doctrine_context", "memo_template_requirements", "rating_rules"]
    },
    {
      "id": "material_organizer",
      "agent": "Material Organizer Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": [],
      "outputs": ["source_documents", "coverage_map", "missing_materials"]
    },
    {
      "id": "evidence_extractor",
      "agent": "Evidence Extractor Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": ["material_organizer"],
      "outputs": ["evidence_items", "financial_fields", "verification_questions"]
    },
    {
      "id": "financial_quality_dividend",
      "agent": "Financial Quality & Dividend Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": ["evidence_extractor", "firm_doctrine_case_retrieval"],
      "outputs": ["financial_quality_output"]
    },
    {
      "id": "business_model_moat",
      "agent": "Business Model & Moat Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": ["evidence_extractor", "firm_doctrine_case_retrieval"],
      "outputs": ["business_model_output"]
    },
    {
      "id": "management_view_comparison",
      "agent": "Management & View Comparison Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": ["evidence_extractor", "financial_quality_dividend", "business_model_moat"],
      "outputs": ["view_comparison_output"]
    },
    {
      "id": "value_trap_contradiction",
      "agent": "Value Trap & Contradiction Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": [
        "evidence_extractor",
        "financial_quality_dividend",
        "business_model_moat",
        "management_view_comparison",
        "firm_doctrine_case_retrieval"
      ],
      "outputs": ["value_trap_output", "counter_evidence_risks"]
    },
    {
      "id": "pre_memo_gate",
      "agent": "Evidence & Compliance Gate Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": [
        "evidence_extractor",
        "financial_quality_dividend",
        "business_model_moat",
        "management_view_comparison",
        "value_trap_contradiction"
      ],
      "outputs": ["pre_memo_gate_output"]
    },
    {
      "id": "research_memo_generator",
      "agent": "Research Memo Generator Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": [
        "firm_doctrine_case_retrieval",
        "material_organizer",
        "evidence_extractor",
        "financial_quality_dividend",
        "business_model_moat",
        "management_view_comparison",
        "value_trap_contradiction",
        "pre_memo_gate"
      ],
      "outputs": ["draft_research_memo"]
    },
    {
      "id": "post_memo_gate",
      "agent": "Evidence & Compliance Gate Agent",
      "required_modes": ["to_c", "to_b"],
      "depends_on": ["research_memo_generator"],
      "outputs": ["post_memo_gate_output", "final_research_memo"]
    }
  ],
  "parallel_groups": [
    {
      "id": "analysis_parallel_group",
      "after": "evidence_extractor",
      "nodes": [
        "financial_quality_dividend",
        "business_model_moat"
      ]
    }
  ],
  "hard_rules": [
    "post_memo_gate must run after research_memo_generator",
    "pre_memo_gate must run before research_memo_generator",
    "value_trap_contradiction cannot be skipped",
    "to_c mode cannot output deterministic investment ratings",
    "missing financial data must remain null or to_be_verified"
  ]
}
